{
	"name": "gouse",
	"displayName": "gouse",
	"publisher": "looshch",
	"description": "Toggle ‘declared and not used’ errors in Go",
	"icon": "icon.png",
	"version": "0.7.2",
	"engines": {
		"vscode": "^1.69.0"
	},
	"activationEvents": [
		"onCommand:gouse.toggle",
		"onLanguage:go"
	],
	"main": "./out/extension.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/vipkek/gouse-vsc"
	},
	"contributes": {
		"commands": [
			{
				"command": "gouse.toggle",
				"title": "gouse: Toggle ‘declared and not used’ errors",
				"enablement": "editorLangId == go && resourceScheme == file"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "gouse.toggle",
					"when": "editorLangId == go"
				}
			],
			"editor/context": [
				{
					"command": "gouse.toggle",
					"when": "editorLangId == go && resourceScheme == file",
					"group": "navigation@50"
				}
			]
		},
		"configuration": {
			"title": "gouse",
			"properties": {
				"gouse.path": {
					"type": "string",
					"default": "",
					"description": "Path to the gouse executable. Leave empty to resolve gouse from PATH."
				},
				"gouse.autoUpdateOnStartup": {
					"type": "boolean",
					"default": true,
					"description": "Automatically update gouse on startup when gouse is already installed and gouse.path is empty."
				}
			}
		}
	},
	"scripts": {
		"build:base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
		"compile": "npm run build:base -- --sourcemap",
		"watch": "npm run build:base -- --sourcemap --watch",
		"typecheck": "tsc --noEmit -p ./",
		"compile-tests": "tsc -p ./tsconfig.test.json && tsc-alias -p ./tsconfig.test.json",
		"test:package": "node ./scripts/check-package.cjs",
		"vscode:prepublish": "npm run build:base -- --minify && npm run test:package",
		"test": "npm run typecheck && npm run lint && npm run compile && npm run compile-tests && npm run test:package && node ./out/test/test/runTest.js",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"format": "prettier --write .",
		"update": "npm update && npm dedupe",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^9.14.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "16.x",
		"@types/vscode": "^1.69.0",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.14.53",
		"eslint": "^9.14.0",
		"eslint-config-prettier": "^9.1.0",
		"globals": "^15.12.0",
		"husky": "^9.1.6",
		"mocha": "^11.1.0",
		"prettier": "^3.3.3",
		"typescript": "^4.7.4",
		"typescript-eslint": "^8.13.0",
		"tsc-alias": "^1.8.16"
	}
}
